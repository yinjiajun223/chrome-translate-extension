{
  "manifest_version": 3,
  "name": "划词翻译插件",
  "version": "1.0.0",
  "description": "选中文本后点击按钮翻译成中文",
  "permissions": [
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "划词翻译"
  }
}
